{
  "name": "smart-attendance-desktop",
  "version": "1.0.0",
  "description": "Smart Attendance System - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis"
  },
  "author": "Smart Attendance",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.smartattendance.desktop",
    "productName": "Smart Attendance System",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "**/*.html",
      "**/*.css",
      "**/*.js",
      "**/node_modules/**"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": ["**/*"]
      }
    ]
  }
}
