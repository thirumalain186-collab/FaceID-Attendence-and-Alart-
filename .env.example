# Environment Variables for Smart Attendance System
# Copy this file to .env and fill in your values

# Email Configuration
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
CLASS_ADVISOR_EMAIL=advisor@college.edu
HOD_EMAIL=hod@college.edu
EMAIL_ENABLED=true

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Application Settings
CLASS_NAME=CS-A
COLLEGE_NAME=Your College Name
CAMERA_INDEX=0
CONFIDENCE_THRESHOLD=80
ALERT_COOLDOWN=60
FRAME_SKIP=3
SAMPLES_PER_PERSON=30

# Schedule Settings
ATTENDANCE_START=09:00
ATTENDANCE_STOP=09:30
DAY_END=16:30
BATCH_DAYS=30

# Flask Settings
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Logging Settings
LOG_LEVEL=INFO
LOG_MAX_SIZE=5242880
LOG_BACKUP_COUNT=5

# Database
DB_PATH=attendance.db
